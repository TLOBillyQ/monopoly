#!/usr/bin/env sh
#
# pre-commit hook — fast architecture guards by default.
#   MONO_FULL=1 git commit   → run full regression suite instead.
#   git commit --no-verify   → bypass all checks.

set -e

cd "$(git rev-parse --show-toplevel)"

# ── locate lua ──────────────────────────────────────────────
LUA=""
for cmd in lua5.4 lua; do
  if command -v "$cmd" >/dev/null 2>&1; then
    LUA="$cmd"
    break
  fi
done

if [ -z "$LUA" ]; then
  echo "[monopoly] warning: lua not found, skipping pre-commit checks"
  exit 0
fi

# ── timer ───────────────────────────────────────────────────
START=$(date +%s)

trap 'elapsed=$(( $(date +%s) - START )); echo "[monopoly] pre-commit finished in ${elapsed}s"' EXIT

# ── run checks ──────────────────────────────────────────────
if [ "${MONO_FULL:-0}" = "1" ]; then
  echo "[monopoly] running full regression (MONO_FULL=1) ..."
  if ! $LUA tests/regression.lua; then
    echo ""
    echo "[monopoly] full regression FAILED — commit blocked."
    echo "  hint: fix the failures, or use 'git commit --no-verify' to bypass."
    exit 1
  fi
else
  echo "[monopoly] running architecture guards ..."

  if ! $LUA tests/internal/dep_rules.lua; then
    echo ""
    echo "[monopoly] dep_rules FAILED — commit blocked."
    echo "  hint: fix violations, or use 'git commit --no-verify' to bypass."
    exit 1
  fi

  if ! $LUA tests/internal/forbidden_globals.lua; then
    echo ""
    echo "[monopoly] forbidden_globals FAILED — commit blocked."
    echo "  hint: fix violations, or use 'git commit --no-verify' to bypass."
    exit 1
  fi
fi
